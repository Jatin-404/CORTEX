# Data
HANDBOOK_ROOT=data/handbook-main/handbook-main/content/handbook

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text:latest
EMBED_DIM=768

# Qdrant — single collection, filter by source_type payload
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=cortex_vectors

# Postgres (host port 5433)
POSTGRES_DSN=postgresql+psycopg://postgres:postgres@localhost:5433/cortex

# Redis — shared by Cortex Celery and Langfuse
REDIS_AUTH=changeme-generate-with-openssl-rand-hex-32
CELERY_BROKER=redis://:changeme@localhost:6379/0
CELERY_BACKEND=redis://:changeme@localhost:6379/1

# Langfuse infra secrets (docker compose ${VAR} substitution)
CLICKHOUSE_PASSWORD=changeme
MINIO_ROOT_PASSWORD=changeme

# Ingestion
SKIP_UNCHANGED=true
DELETE_STALE_CHUNKS=true
LOG_LEVEL=INFO

# Retrieval / reranking (Stage 2a)
RERANK_ENABLED=true
RETRIEVE_CANDIDATES=20
RERANK_TOP_K=5
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_MAX_CHARS=1500

# LLM synthesis (Stage 2b)
LLM_MODEL=llama3.2:latest
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=180
SYNTHESIS_CONTEXT_CHARS=1200

# Grader / Corrective-RAG (Stage 2c)
GRADER_ENABLED=true
GRADER_MAX_RETRIES=2
GRADER_MODEL=
GRADER_FAST_PASS_SCORE=0.75
GRADER_MIN_RERANK_SCORE=0.30
GRADER_CONTEXT_CHARS=800

# LangGraph agent (Stage 2d)
LANGGRAPH_CHECKPOINT_BACKEND=postgres

# Langfuse (Stage 2e) — API keys from http://localhost:3000 after signup
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

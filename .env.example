# Data
HANDBOOK_ROOT=data/handbook-main/handbook-main/content/handbook

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text:latest
EMBED_DIM=768

# Qdrant — single collection, filter by source_type payload
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=cortex_vectors

# Postgres
POSTGRES_DSN=postgresql+psycopg://cortex:cortex@localhost:5432/cortex

# Celery
CELERY_BROKER=redis://localhost:6379/0
CELERY_BACKEND=redis://localhost:6379/1

# Ingestion
SKIP_UNCHANGED=true
DELETE_STALE_CHUNKS=true
LOG_LEVEL=INFO
